# Ignore cache
datasets/Deepfake-Eval-2024/.cache/

# Ignore all data files inside these directories
datasets/Deepfake-Eval-2024/audio-data/*
datasets/Deepfake-Eval-2024/in_the_wild_test/*
datasets/Deepfake-Eval-2024/la_test/fake/*
datasets/Deepfake-Eval-2024/la_test/real/*

# EXCEPTIONS: Do not ignore .csv files in these directories
!datasets/Deepfake-Eval-2024/audio-data/*.csv
!datasets/Deepfake-Eval-2024/la_test/*.csv

# EXCEPTIONS: Do not ignore the .gitkeep files (keeps the folder structure)
!datasets/Deepfake-Eval-2024/audio-data/.gitkeep
!datasets/Deepfake-Eval-2024/in_the_wild_test/.gitkeep
!datasets/Deepfake-Eval-2024/la_test/fake/.gitkeep
!datasets/Deepfake-Eval-2024/la_test/real/.gitkeep


